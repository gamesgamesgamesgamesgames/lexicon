{
	"name": "@lexicon/root",
	"private": true,
	"version": "0.0.0",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"dev": "bun run --filter='@lexicon/docs' dev",
		"build": "bun run --filter='@lexicon/docs' build",
		"generate:reference": "bun run --filter='@lexicon/docs' generate:reference",
		"lint": "bun run --filter='*' lint",
		"typecheck": "bun run --filter='*' typecheck",
		"test": "bun run --filter='*' test"
	},
	"devDependencies": {
		"typescript": "^5.6.0"
	},
	"packageManager": "bun@1.1.0"
}
