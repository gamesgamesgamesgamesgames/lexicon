{
  "lexicon": 1,
  "id": "social.popfeed.feed.review",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": [
          "identifiers",
          "creativeWorkType",
          "rating",
          "createdAt"
        ],
        "properties": {
          "identifiers": {
            "type": "ref",
            "ref": "#identifiers"
          },
          "creativeWorkType": {
            "type": "string",
            "enum": ["movie", "tv_show", "video_game", "album", "book", "book_series", "episode", "album", "ep", "tv_season", "tv_episode", "track"]
          },
          "rating": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10
          },
          "text": {
            "type": "string",
            "maxLength": 100000
          },
          "facets": {
            "type": "array",
            "description": "Annotations of text (mentions, URLs, hashtags, etc)",
            "items": { "type": "ref", "ref": "social.popfeed.richtext.facet" }
          },
          "poster": {
            "type": "blob",
            "accept": [
              "image/*"
            ],
            "maxSize": 2000000
          },
          "backdrop": {
            "type": "blob",
            "accept": [
              "image/*"
            ],
            "maxSize": 4000000,
            "description": "Backdrop image for the review post. Have not fully cut over yet so may not be shown"
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 50
            }
          },
          "title": {
            "type": "string",
            "maxLength": 1000,
            "description": "Title of the creative work."
          },
          "posterUrl": {
            "type": "string",
            "format": "uri",
            "description": "Poster or cover image URL for the creative work. Soon to be deprecated in favor of the 'poster' blob field"
          },
          "backdropUrl": {
            "type": "string",
            "format": "uri",
            "description": "Backdrop image URL for the creative work. Soon to be deprecated in favor of the 'backdrop' blob field"
          },
          "releaseDate": {
            "type": "string",
            "format": "datetime",
            "description": "Release date of the creative work."
          },
          "genres": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 50
            }
          },
          "mainCredit": {
            "type": "string",
            "maxLength": 1000,
            "description": "Main actor, director, author, or artist of the creative work."
          },
          "mainCreditRole": {
            "type": "string",
            "enum": ["director", "author", "artist", "showrunner", "lead_actor", "creator", "studio", "publisher", "developer", "performer", "network"],
            "description": "The role of the main credit."
          },
          "isRevisit": {
            "type": "boolean",
            "description": "Indicates if the user has experienced this work before (re-watch, re-read, replay)."
          },
          "containsSpoilers": {
            "type": "boolean",
            "description": "Indicates if the review contains spoilers."
          },
          "crossPosts": {
            "type": "ref",
            "ref": "#crossPosts",
            "description": "Information about cross-posting to other platforms."
          }
        }
      }
    },
    "identifiers": {
      "type": "object",
      "properties": {
        "imdbId": { "type": "string" },
        "isbn10": { "type": "string" },
        "isbn13": { "type": "string" },
        "asin": { "type": "string" },
        "other": { "type": "string" },
        "tmdbId": { "type": "string" },
        "igdbId": { "type": "string" },
        "mbId": { "type": "string", "description": "DEPRECATED - soon to be ignored" },
        "mbReleaseId": { "type": "string", "description": "MusicBrainz ID for specific releases (albums, EPs, tracks)" },
        "parentMbReleaseId": { "type": "string", "description": "MusicBrainz ID for parent release (e.g., album for a track)" },
        "episodeNumber": {
          "type": "integer",
          "description": "Episode number for TV shows or series"
        },
        "seasonNumber": {
          "type": "integer",
          "description": "Season number for TV shows or series"
        },
        "tmdbTvSeriesId": {
          "type": "string",
          "description": "TMDb ID for TV series"
        }
      }
    },
    "crossPosts": {
      "type": "object",
      "properties": {
        "leaflet": {
          "type": "string",
          "format": "uri",
          "description": "The URI of the original Leaflet post being cross-posted."
        },
        "bluesky": {
          "type": "string",
          "format": "uri",
          "description": "The URI of the original Bluesky post being cross-posted."
        }
      }
    }
  }
}
