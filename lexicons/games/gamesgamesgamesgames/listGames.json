{
	"$type": "com.atproto.lexicon.schema",
	"lexicon": 1,
	"id": "games.gamesgamesgamesgames.listGames",
	"defs": {
		"main": {
			"type": "query",
			"description": "Get a list of games on the network.",
			"parameters": {
				"type": "params",
				"properties": {
					"cursor": {
						"type": "string"
					},
					"did": {
						"type": "string",
						"format": "did"
					},
					"limit": {
						"type": "integer",
						"minimum": 1,
						"maximum": 100,
						"default": 20
					},
					"sort": {
						"type": "string",
						"description": "Field to sort by (e.g. name, createdAt, indexed_at).",
						"default": "indexed_at"
					},
					"sortDirection": {
						"type": "string",
						"description": "Sort direction.",
						"enum": ["asc", "desc"],
						"default": "desc"
					},
					"applicationTypes": {
						"type": "array",
						"description": "Filter by application type (e.g. game, dlc, bundle).",
						"items": {
							"type": "string",
							"knownValues": [
								"addon",
								"bundle",
								"dlc",
								"episode",
								"expandedGame",
								"expansion",
								"fork",
								"game",
								"mod",
								"pack",
								"port",
								"remake",
								"remaster",
								"season",
								"standaloneExpansion",
								"update"
							]
						}
					},
					"genres": {
						"type": "array",
						"items": { "type": "string" }
					},
					"themes": {
						"type": "array",
						"items": { "type": "string" }
					},
					"modes": {
						"type": "array",
						"items": { "type": "string" }
					},
					"playerPerspectives": {
						"type": "array",
						"items": { "type": "string" }
					},
					"ageRatings": {
						"type": "array",
						"description": "Filter by age rating in 'organization:rating' format (e.g. esrb:M, pegi:Eighteen).",
						"items": { "type": "string" }
					},
					"includeUnrated": {
						"type": "boolean",
						"description": "When age rating filters are active, also include games with no age ratings.",
						"default": false
					},
					"includeCancelled": {
						"type": "boolean",
						"default": false
					}
				}
			},
			"output": {
				"encoding": "application/json",
				"schema": {
					"type": "object",
					"required": ["games"],
					"properties": {
						"cursor": { "type": "string" },
						"games": {
							"type": "array",
							"items": {
								"type": "ref",
								"ref": "games.gamesgamesgamesgames.defs#gameSummaryView"
							}
						}
					}
				}
			}
		}
	}
}
