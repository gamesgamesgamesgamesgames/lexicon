{
	"lexicon": 1,
	"id": "games.gamesgamesgamesgames.richtext.facet",
	"defs": {
		"main": {
			"type": "object",
			"description": "Annotation of a sub-string within rich text.",
			"required": ["index", "features"],
			"properties": {
				"index": { "type": "ref", "ref": "#byteSlice" },
				"features": {
					"type": "array",
					"items": {
						"type": "union",
						"refs": [
							"#mention",
							"#link",
							"#tag",
							"#bold",
							"#italic",
							"#heading",
							"#listItem",
							"#image",
							"#video"
						]
					}
				}
			}
		},
		"mention": {
			"type": "object",
			"description": "Facet feature for mention of another account.",
			"required": ["did"],
			"properties": {
				"did": { "type": "string", "format": "did" }
			}
		},
		"link": {
			"type": "object",
			"description": "Facet feature for a URL.",
			"required": ["uri"],
			"properties": {
				"uri": { "type": "string", "format": "uri" }
			}
		},
		"tag": {
			"type": "object",
			"description": "Facet feature for a hashtag.",
			"required": ["tag"],
			"properties": {
				"tag": { "type": "string", "maxLength": 640, "maxGraphemes": 64 }
			}
		},
		"bold": {
			"type": "object",
			"description": "Facet feature for bold text.",
			"properties": {}
		},
		"italic": {
			"type": "object",
			"description": "Facet feature for italic text.",
			"properties": {}
		},
		"heading": {
			"type": "object",
			"description": "Facet feature for a section heading.",
			"required": ["level"],
			"properties": {
				"level": { "type": "integer", "minimum": 1, "maximum": 6 }
			}
		},
		"listItem": {
			"type": "object",
			"description": "Facet feature marking text as a list item.",
			"properties": {
				"ordered": { "type": "boolean" },
				"depth": { "type": "integer", "minimum": 0, "default": 0 }
			}
		},
		"image": {
			"type": "object",
			"description": "Facet feature for an inline image.",
			"required": ["blob"],
			"properties": {
				"blob": { "type": "blob", "accept": ["image/*"], "maxSize": 10000000 },
				"alt": { "type": "string" },
				"width": { "type": "integer" },
				"height": { "type": "integer" }
			}
		},
		"video": {
			"type": "object",
			"description": "Facet feature for an inline video.",
			"properties": {
				"blob": { "type": "blob", "accept": ["video/*"], "maxSize": 200000000 },
				"uri": { "type": "string", "format": "uri" },
				"alt": { "type": "string" }
			}
		},
		"byteSlice": {
			"type": "object",
			"description": "Specifies the sub-string range a facet feature applies to. Start index is inclusive, end index is exclusive. Indices are zero-indexed, counting bytes of the UTF-8 encoded text.",
			"required": ["byteStart", "byteEnd"],
			"properties": {
				"byteStart": { "type": "integer", "minimum": 0 },
				"byteEnd": { "type": "integer", "minimum": 0 }
			}
		}
	}
}
