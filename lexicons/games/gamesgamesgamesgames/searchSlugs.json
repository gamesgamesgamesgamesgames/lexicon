{
	"$type": "com.atproto.lexicon.schema",
	"lexicon": 1,
	"id": "games.gamesgamesgamesgames.searchSlugs",
	"defs": {
		"main": {
			"type": "query",
			"description": "Search for slug records by slug value to check availability.",
			"parameters": {
				"type": "params",
				"required": ["slug"],
				"properties": {
					"slug": {
						"type": "string",
						"description": "The slug value to search for.",
						"minLength": 1,
						"maxLength": 64
					},
					"limit": {
						"type": "integer",
						"default": 10,
						"maximum": 100
					}
				}
			},
			"output": {
				"encoding": "application/json",
				"schema": {
					"type": "object",
					"required": ["slugs"],
					"properties": {
						"slugs": {
							"type": "array",
							"items": {
								"type": "ref",
								"ref": "games.gamesgamesgamesgames.searchSlugs#slugResult"
							}
						}
					}
				}
			}
		},

		"slugResult": {
			"type": "object",
			"required": ["slug", "ref"],
			"properties": {
				"slug": { "type": "string" },
				"ref": { "type": "string", "format": "at-uri" }
			}
		}
	}
}
