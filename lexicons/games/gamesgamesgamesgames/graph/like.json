{
	"$type": "com.atproto.lexicon.schema",
	"lexicon": 1,
	"id": "games.gamesgamesgamesgames.graph.like",
	"defs": {
		"main": {
			"type": "record",
			"description": "Record representing a user's like of a game.",
			"key": "tid",
			"record": {
				"type": "object",
				"required": ["subject", "createdAt"],
				"properties": {
					"subject": {
						"type": "string",
						"format": "at-uri",
						"description": "AT URI of the game record being liked."
					},
					"createdAt": {
						"type": "string",
						"format": "datetime"
					}
				}
			}
		}
	}
}
