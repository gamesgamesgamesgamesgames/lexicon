{
  "$type": "com.atproto.lexicon.schema",
  "lexicon": 1,
  "id": "games.gamesgamesgamesgames.getUserLists",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get a user's lists with item counts. Optionally check which lists contain a specific game.",
      "parameters": {
        "type": "params",
        "required": ["did"],
        "properties": {
          "did": {
            "type": "string",
            "description": "The DID of the user whose lists to retrieve."
          },
          "gameUri": {
            "type": "string",
            "format": "at-uri",
            "description": "If provided, each list includes a hasGame boolean indicating whether this game is in the list."
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["lists"],
          "properties": {
            "lists": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "#userListView"
              }
            },
            "cursor": {
              "type": "string"
            }
          }
        }
      }
    },
    "userListView": {
      "type": "object",
      "required": ["uri", "name", "itemCount", "createdAt"],
      "properties": {
        "uri": {
          "type": "string",
          "format": "at-uri"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "itemCount": {
          "type": "integer"
        },
        "hasGame": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "datetime"
        }
      }
    }
  }
}
