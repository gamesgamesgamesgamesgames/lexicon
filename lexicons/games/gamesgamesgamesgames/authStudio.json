{
	"lexicon": 1,
	"id": "games.gamesgamesgamesgames.authStudio",
	"defs": {
		"main": {
			"type": "permission-set",
			"title": "Studio",
			"detail": "Manage studio profiles, create and edit games, and handle ownership claims and contributions.",
			"permissions": [
				{
					"type": "permission",
					"resource": "repo",
					"collection": [
						"games.gamesgamesgamesgames.claim",
						"games.gamesgamesgamesgames.engine",
						"games.gamesgamesgamesgames.game",
						"games.gamesgamesgamesgames.org.credit",
						"games.gamesgamesgamesgames.org.profile",
						"games.gamesgamesgamesgames.platform",
						"games.gamesgamesgamesgames.platformFamily"
					]
				},
				{
					"type": "permission",
					"resource": "rpc",
					"inheritAud": true,
					"lxm": [
						"games.gamesgamesgamesgames.acceptContribution",
						"games.gamesgamesgamesgames.createClaim",
						"games.gamesgamesgamesgames.createGame",
						"games.gamesgamesgamesgames.getClaim",
						"games.gamesgamesgamesgames.listClaims",
						"games.gamesgamesgamesgames.migrateClaim",
						"games.gamesgamesgamesgames.org.createProfile",
						"games.gamesgamesgamesgames.org.getProfile",
						"games.gamesgamesgamesgames.org.putProfile",
						"games.gamesgamesgamesgames.putGame"
					]
				}
			]
		}
	}
}
